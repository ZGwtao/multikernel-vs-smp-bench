 build_sdk.py | 6 +++---
 1 file changed, 3 insertions(+), 3 deletions(-)

diff --git a/build_sdk.py b/build_sdk.py
index 1bc0e3a..57c5368 100644
--- a/build_sdk.py
+++ b/build_sdk.py
@@ -46,10 +46,10 @@ DEFAULT_KERNEL_OPTIONS = {
 }
 
