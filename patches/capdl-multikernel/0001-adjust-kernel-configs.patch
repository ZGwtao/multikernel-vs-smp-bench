+        kernel_options_arch={
+            KernelArch.AARCH64: {
+                "KernelArmExportPMUUser": True,
+            },
         },
-        kernel_options_arch={},
     ),
     ConfigInfo(
         name="debug",
@@ -439,7 +440,11 @@ SUPPORTED_CONFIGS = (
             "KernelPrinting": True,
             "KernelVerificationBuild": False
         },
-        kernel_options_arch={},
+        kernel_options_arch={
+            KernelArch.AARCH64: {
+                "KernelArmExportPMUUser": True,
+            },
+        },
     ),
     ConfigInfo(
         name="benchmark",
@@ -449,6 +454,7 @@ SUPPORTED_CONFIGS = (
             "KernelVerificationBuild": False,
             "KernelBenchmarks": "track_utilisation",
             "KernelSignalFastpath": True,
+            "HardwareDebugAPI": False,
         },
