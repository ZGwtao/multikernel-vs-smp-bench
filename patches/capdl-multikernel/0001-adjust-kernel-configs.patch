 build_sdk.py | 20 +++++++++++++-------
 1 file changed, 13 insertions(+), 7 deletions(-)

diff --git a/build_sdk.py b/build_sdk.py
index 9112edd..c74f183 100644
--- a/build_sdk.py
+++ b/build_sdk.py
@@ -249,9 +249,7 @@ SUPPORTED_BOARDS = (
