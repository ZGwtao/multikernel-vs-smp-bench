From abe3df7194751a7ea396ac02131e1b6b3567056f Mon Sep 17 00:00:00 2001
From: Guangtao Zhu <guangtaozhu@outlook.com>
Date: Thu, 14 May 2026 20:31:17 +1000
Subject: [PATCH] allow user-level code to read cntvct

Signed-off-by: Guangtao Zhu <guangtaozhu@outlook.com>
---
 src/arch/arm/kernel/boot.c | 17 +++++++++++++++++
 1 file changed, 17 insertions(+)

diff --git a/src/arch/arm/kernel/boot.c b/src/arch/arm/kernel/boot.c
index 86f76210..04df48d2 100644
--- a/src/arch/arm/kernel/boot.c
+++ b/src/arch/arm/kernel/boot.c
@@ -311,6 +311,15 @@ BOOT_CODE static bool_t try_init_kernel_secondary_core(void)
     setIRQState(IRQReserved, CORE_IRQ_TO_IRQT(getCurrentCPUIndex(), INTERRUPT_VGIC_MAINTENANCE));
     setIRQState(IRQReserved, CORE_IRQ_TO_IRQT(getCurrentCPUIndex(), INTERRUPT_VTIMER_EVENT));
 #endif /* CONFIG_ARM_HYPERVISOR_SUPPORT */
+
+    uint64_t v;
+
+    asm volatile("mrs %0, cntkctl_el1" : "=r"(v));
+    v |= (1ull << 1);  // EL0VCTEN: allow EL0 to read CNTVCT_EL0
+    v |= (1ull << 0);  // EL0PCTEN: allow EL0 to read CNTPCT_EL0, if needed
+    asm volatile("msr cntkctl_el1, %0" :: "r"(v));
+    asm volatile("isb");
+
     NODE_LOCK_SYS;
 
     clock_sync_test();
@@ -833,6 +842,14 @@ static BOOT_CODE bool_t try_init_kernel(paddr_t kernel_boot_info_p)
     SMP_COND_STATEMENT(clh_lock_init());
     SMP_COND_STATEMENT(release_secondary_cpus());
 
+    uint64_t v;
+
+    asm volatile("mrs %0, cntkctl_el1" : "=r"(v));
+    v |= (1ull << 1);  // EL0VCTEN: allow EL0 to read CNTVCT_EL0
+    v |= (1ull << 0);  // EL0PCTEN: allow EL0 to read CNTPCT_EL0, if needed
+    asm volatile("msr cntkctl_el1, %0" :: "r"(v));
+    asm volatile("isb");
+
     /* All cores are up now, so there can be concurrency. The kernel booting is
      * supposed to be finished before the secondary cores are released, all the
      * primary has to do now is schedule the initial thread. Currently there is
-- 
2.43.0

